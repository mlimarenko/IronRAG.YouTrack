# --- YouTrack Knowledge Base ---
YOUTRACK_BASE_URL=https://tracker.example.com/youtrack
# Permanent token scoped to YouTrack. The token user needs Read Project Basic
# and Read Article only for the projects intended for ingestion.
YOUTRACK_TOKEN=perm:replace-me
YOUTRACK_PAGE_SIZE=100
YOUTRACK_RETRY_MAX=5
YOUTRACK_RETRY_BACKOFF_SECONDS=1
YOUTRACK_RETRY_MAX_SLEEP_SECONDS=30
YOUTRACK_MIN_REQUEST_INTERVAL_SECONDS=0.1
# Two or three matching snapshots protect offset pagination from concurrent mutation.
YOUTRACK_SNAPSHOT_VALIDATION_PASSES=2
# Optional exact project database IDs and/or short names, comma-separated.
YOUTRACK_PROJECTS=
YOUTRACK_EXCLUDE_PROJECTS=
YOUTRACK_INCLUDE_ARCHIVED_PROJECTS=false

# --- IronRAG ---
IRONRAG_BASE_URL=https://ironrag.example.com
IRONRAG_API_TOKEN=irt_replace_me
REQUEST_TIMEOUT_SECONDS=60
# IRONRAG_MUTATION_TIMEOUT_SECONDS=55
CURSOR_LIBRARY_LOOKUP_TIMEOUT_SECONDS=5
CURSOR_LIBRARY_LOOKUP_MAX_ROWS_PER_SWEEP=16
REAPER_LIST_TIMEOUT_SECONDS=30

# --- Routing and reconciliation ---
ROUTING_CONFIG_PATH=/app/routing.yaml
RUN_MODE=poll
SYNC_INTERVAL_SECONDS=1800
SYNC_RUN_ON_STARTUP=false
SYNC_CONCURRENCY=4
SYNC_ITEM_TIMEOUT_SECONDS=300
DEFAULT_POLICY_ON_NEW=create
DEFAULT_POLICY_ON_CHANGED=replace
DEFAULT_POLICY_ON_MISSING=delete
DEFAULT_POLICY_ON_DUPLICATE_CONTENT=skip

# --- State and HTTP admin surface ---
STATE_DB_PATH=/var/lib/ironrag-connector/state.sqlite
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info
ADMIN_BEARER_TOKEN=replace-me
