# --- YouTrack Knowledge Base ---
YOUTRACK_BASE_URL=https://tracker.example.com/youtrack
# Permanent token scoped to YouTrack. The token user needs Read Project Basic
# and Read Article only for the projects intended for ingestion.
YOUTRACK_TOKEN=perm:replace-me
YOUTRACK_PAGE_SIZE=100 # integer 1..500
YOUTRACK_RETRY_MAX=5 # integer 0..20
YOUTRACK_RETRY_BACKOFF_SECONDS=1 # number >= 0.1
YOUTRACK_RETRY_MAX_SLEEP_SECONDS=30 # number >= 0.1
YOUTRACK_MIN_REQUEST_INTERVAL_SECONDS=0.1 # number >= 0
# Integer 2 or 3; matching snapshots protect offset pagination from mutation.
YOUTRACK_SNAPSHOT_VALIDATION_PASSES=2
# Optional exact project database IDs and/or short names, comma-separated.
YOUTRACK_PROJECTS=
YOUTRACK_EXCLUDE_PROJECTS=
YOUTRACK_INCLUDE_ARCHIVED_PROJECTS=false # true | false

# --- IronRAG ---
IRONRAG_BASE_URL=https://ironrag.example.com
IRONRAG_API_TOKEN=irt_replace_me
REQUEST_TIMEOUT_SECONDS=60 # number >= 1
# Optional number >= 1; derived from request/item timeouts when omitted.
# IRONRAG_MUTATION_TIMEOUT_SECONDS=55
CURSOR_LIBRARY_LOOKUP_TIMEOUT_SECONDS=5 # number >= 0.1
CURSOR_LIBRARY_LOOKUP_MAX_ROWS_PER_SWEEP=16 # integer >= 0
REAPER_LIST_TIMEOUT_SECONDS=30 # number >= 1

# --- Routing and reconciliation ---
ROUTING_CONFIG_PATH=/app/routing.yaml
RUN_MODE=poll # poll is required: YouTrack KB has no lifecycle webhooks
SYNC_INTERVAL_SECONDS=1800 # integer >= 60
SYNC_RUN_ON_STARTUP=false # true | false
SYNC_CONCURRENCY=4 # integer 1..64
SYNC_ITEM_TIMEOUT_SECONDS=300 # number >= 1
DEFAULT_POLICY_ON_NEW=create # create | skip
DEFAULT_POLICY_ON_CHANGED=replace # replace | skip
DEFAULT_POLICY_ON_MISSING=delete # delete | ignore
DEFAULT_POLICY_ON_DUPLICATE_CONTENT=skip # skip | fail

# --- State and HTTP admin surface ---
STATE_DB_PATH=/var/lib/ironrag-connector/state.sqlite
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info
# Optional filesystem path; defaults to /tmp/<connector-name>.pid.
# PIDFILE_PATH=/tmp/youtrack-connector.pid
ADMIN_BEARER_TOKEN=replace-me
